# Ficheiros sensíveis
# =============================================
.env
.env.local
.env.*.local
*.key
*.pem
*.secrets

# =============================================
# Deploy e ferramentas (Vercel)
# =============================================
.vercel
/.vercel
/deploy-vercel/
.vercel.json

