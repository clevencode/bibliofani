# =============================================
# Flutter / Dart
# =============================================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/doc/api/
.build/
.buildlog/
coverage/
*.lcov

# Pacotes locais em path: a resolução fica no pubspec.lock da raiz.
packages/**/pubspec.lock

# Builds do Flutter — ignorar por completo (Vercel / CI geram com flutter build web).
# Opcional, se um dia quiseres versionar artefactos web: usar /build/* + !/build/web/**
/build/

# =============================================
# Android
# =============================================
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/.gradle/
/android/app/google-services.json

# =============================================
# iOS
# =============================================
/ios/Flutter/.last_build_id
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/App.framework/
/ios/Flutter/Flutter.podspec

# =============================================
# IDEs e editores
# =============================================
.idea/
*.iml
*.ipr
*.iws

.vscode/
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# =============================================
# Sistema e diversos
# =============================================
.DS_Store
*.log
*.swp
*.swo
*.class
*.pyc
*.pyo
.atom/
.history/
.svn/
.swiftpm/
migrate_working_dir/
.migrate_working_dir/

